    <style>
        :root {
            --bg: #eef3f8;
            --panel: rgba(251, 253, 255, 0.85);
            --panel-solid: #fbfdff;
            --panel-2: #f5f8fb;
            --text: #17202a;
            --muted: #657282;
            --line: rgba(26, 42, 58, 0.08);
            --primary: #2563eb;
            --primary-light: rgba(37, 99, 235, 0.06);
            --shadow: 0 16px 36px rgba(31, 45, 61, 0.05);
            --soft: 0 6px 16px rgba(31, 45, 61, 0.03);
            --radius: 16px;
            --radius-sm: 12px;
            --nav-h: 56px;
            --accent-green: #10b981;
            --accent-orange: #f59e0b;
        }

        [data-theme="dark"] {
            --bg: #121722;
            --panel: rgba(26, 34, 48, 0.85);
            --panel-solid: #1a2230;
            --panel-2: #111827;
            --text: #edf2f7;
            --muted: #9aa8ba;
            --line: rgba(255, 255, 255, 0.06);
            --primary: #60a5fa;
            --primary-light: rgba(96, 165, 250, 0.1);
            --shadow: 0 16px 40px rgba(0, 0, 0, 0.2);
            --soft: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: "Plus Jakarta Sans", system-ui, sans-serif;
        }

        body {
            min-height: 100vh;
            background: var(--bg);
            color: var(--text);
            padding-bottom: 30px;
        }

        /* Nav Framework */
        nav {
            height: var(--nav-h);
            background: var(--panel);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--line);
            display: flex;
            align-items: center;
            padding: 0 16px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        .back-link {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--panel-2);
            border: 1px solid var(--line);
            color: var(--text);
            display: grid;
            place-items: center;
            text-decoration: none;
            font-size: 13px;
            transition: all 0.2s ease;
        }

        .back-link:hover {
            background: var(--line);
            transform: translateX(-2px);
        }

        .nav-left h1 {
            font-size: 16px;
            font-weight: 800;
            letter-spacing: -0.3px;
        }

        /* Desktop Optimization & Fluid Container */
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        /* Hero Element Setup */
        .chapter-hero {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: 20px 16px;
            box-shadow: var(--shadow);
        }

        .meta-badge {
            display: inline-block;
            padding: 3px 8px;
            background: var(--primary-light);
            color: var(--primary);
            font-size: 10px;
            font-weight: 700;
            border-radius: 30px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .chapter-hero h2 {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.5px;
            line-height: 1.2;
            margin-bottom: 6px;
        }

        .chapter-hero p {
            color: var(--muted);
            font-size: 12.5px;
            line-height: 1.45;
        }

        /* Core Card Panels Structure */
        .panel {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 16px;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
            border-bottom: 1px solid var(--line);
            padding-bottom: 8px;
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title i {
            font-size: 14px;
            color: var(--primary);
        }

        .panel-title h3 {
            font-size: 14.5px;
            font-weight: 800;
            letter-spacing: -0.2px;
        }

        /* Language Controls Group */
        .lang-switch-box {
            display: flex;
            background: var(--panel-2);
            padding: 2px;
            border-radius: 30px;
            border: 1px solid var(--line);
        }

        .lang-btn {
            background: none;
            border: none;
            padding: 4px 10px;
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            cursor: pointer;
            border-radius: 30px;
            transition: all 0.2s;
        }

        .lang-btn.active {
            background: var(--primary);
            color: #ffffff;
        }

        /* Text Engine Architecture (Optimized for Android Screens) */
        .summary-content-area {
            font-size: 13.5px;
            line-height: 1.6;
            color: var(--text);
        }

        .summary-paragraph {
            margin-bottom: 10px;
            text-align: justify;
            animation: textFadeIn 0.25s ease-out;
        }

        /* Layout Component Stacks */
        .qa-stack,
        .quiz-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .qa-card,
        .quiz-card {
            background: var(--panel-2);
            border: 1px solid var(--line);
            border-radius: var(--radius-sm);
            padding: 12px;
            transition: transform 0.2s, border-color 0.2s;
        }

        .qa-question,
        .quiz-question {
            font-size: 13.5px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            gap: 6px;
            line-height: 1.4;
            margin-bottom: 8px;
        }

        .qa-question span,
        .quiz-question span {
            color: var(--primary);
            font-weight: 800;
        }

        .qa-answer {
            font-size: 12.5px;
            line-height: 1.5;
            color: var(--muted);
            padding-left: 14px;
            border-left: 2px solid var(--line);
        }

        /* --- New Interactive Sections Options Engine --- */
        .options-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
            margin-top: 8px;
        }

        .option-item {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            padding: 10px 12px;
            border-radius: var(--radius-sm);
            font-size: 12.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .option-item:hover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .option-item input[type="radio"] {
            accent-color: var(--primary);
        }

        /* Input Configuration for Fills */
        .fill-input {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            padding: 6px 10px;
            border-radius: 8px;
            font-size: 12.5px;
            color: var(--text);
            width: 100%;
            max-width: 240px;
            outline: none;
            margin-top: 6px;
            transition: border-color 0.2s;
        }

        .fill-input:focus {
            border-color: var(--primary);
        }

        /* Writer Biography Structure */
        .writer-profile-box {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .writer-avatar-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--primary);
            display: grid;
            place-items: center;
            font-size: 18px;
            border: 1px solid var(--line);
            flex-shrink: 0;
        }

        .writer-bio-text h4 {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .writer-bio-text p {
            font-size: 12.5px;
            color: var(--muted);
            line-height: 1.5;
        }

        /* --- Desktop Viewport Up-Scaling Optimization --- */
        @media (min-width: 768px) {
            :root {
                --nav-h: 64px;
                --radius: 20px;
                --radius-sm: 14px;
            }

            .container {
                padding: 20px;
                gap: 20px;
                /* Side-by-side components grid framework for Desktop view symmetry */
                display: grid;
                grid-template-columns: repeat(2, 1fr);
            }

            .chapter-hero,
            .writer-panel {
                grid-column: span 2;
            }

            .nav-left h1 {
                font-size: 18px;
            }

            .chapter-hero h2 {
                font-size: 26px;
            }

            .chapter-hero p {
                font-size: 14px;
            }

            .options-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .fill-input {
                width: auto;
            }
        }

        @keyframes textFadeIn {
            from {
                opacity: 0;
                transform: translateY(2px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        * {
            user-select: none;
            -webkit-user-select: none;
            -webkit-touch-callout: none;
        }

        img {
            pointer-events: none;
            -webkit-user-drag: none;
        }
    </style>
</head>

