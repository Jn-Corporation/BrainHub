<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>The Little Girl - Brain Hub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="manifest" href="../../../../manifest.json">
    <meta name="theme-color" content="#2563eb" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#121722" media="(prefers-color-scheme: dark)">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#121722" media="(prefers-color-scheme: dark)">

    <link rel="manifest" href="../../../../manifest.json">
    <link rel="apple-touch-icon" href="../../../../icon-192.png">
    <link rel="icon" type="image/png" sizes="192x192" href="../../../../icon-192.png">

    <style>
        :root {
            --bg: #eef3f8;
            --panel: rgba(251, 253, 255, 0.85);
            --panel-solid: #fbfdff;
            --panel-2: #f5f8fb;
            --text: #17202a;
            --muted: #657282;
            --line: rgba(26, 42, 58, 0.08);
            --primary: #2563eb;
            --primary-light: rgba(37, 99, 235, 0.06);
            --shadow: 0 16px 36px rgba(31, 45, 61, 0.05);
            --soft: 0 6px 16px rgba(31, 45, 61, 0.03);
            --radius: 16px;
            --radius-sm: 12px;
            --nav-h: 56px;
            --accent-green: #10b981;
            --accent-orange: #f59e0b;
        }

        [data-theme="dark"] {
            --bg: #121722;
            --panel: rgba(26, 34, 48, 0.85);
            --panel-solid: #1a2230;
            --panel-2: #111827;
            --text: #edf2f7;
            --muted: #9aa8ba;
            --line: rgba(255, 255, 255, 0.06);
            --primary: #60a5fa;
            --primary-light: rgba(96, 165, 250, 0.1);
            --shadow: 0 16px 40px rgba(0, 0, 0, 0.2);
            --soft: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: "Plus Jakarta Sans", system-ui, sans-serif;
        }

        body {
            min-height: 100vh;
            background: var(--bg);
            color: var(--text);
            padding-bottom: 30px;
        }

        /* Nav Framework */
        nav {
            height: var(--nav-h);
            background: var(--panel);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--line);
            display: flex;
            align-items: center;
            padding: 0 16px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        .back-link {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--panel-2);
            border: 1px solid var(--line);
            color: var(--text);
            display: grid;
            place-items: center;
            text-decoration: none;
            font-size: 13px;
            transition: all 0.2s ease;
        }

        .back-link:hover {
            background: var(--line);
            transform: translateX(-2px);
        }

        .nav-left h1 {
            font-size: 16px;
            font-weight: 800;
            letter-spacing: -0.3px;
        }

        /* Desktop Optimization & Fluid Container */
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        /* Hero Element Setup */
        .chapter-hero {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: 20px 16px;
            box-shadow: var(--shadow);
        }

        .meta-badge {
            display: inline-block;
            padding: 3px 8px;
            background: var(--primary-light);
            color: var(--primary);
            font-size: 10px;
            font-weight: 700;
            border-radius: 30px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .chapter-hero h2 {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.5px;
            line-height: 1.2;
            margin-bottom: 6px;
        }

        .chapter-hero p {
            color: var(--muted);
            font-size: 12.5px;
            line-height: 1.45;
        }

        /* Core Card Panels Structure */
        .panel {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 16px;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
            border-bottom: 1px solid var(--line);
            padding-bottom: 8px;
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title i {
            font-size: 14px;
            color: var(--primary);
        }

        .panel-title h3 {
            font-size: 14.5px;
            font-weight: 800;
            letter-spacing: -0.2px;
        }

        /* Language Controls Group */
        .lang-switch-box {
            display: flex;
            background: var(--panel-2);
            padding: 2px;
            border-radius: 30px;
            border: 1px solid var(--line);
        }

        .lang-btn {
            background: none;
            border: none;
            padding: 4px 10px;
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            cursor: pointer;
            border-radius: 30px;
            transition: all 0.2s;
        }

        .lang-btn.active {
            background: var(--primary);
            color: #ffffff;
        }

        /* Text Engine Architecture (Optimized for Android Screens) */
        .summary-content-area {
            font-size: 13.5px;
            line-height: 1.6;
            color: var(--text);
        }

        .summary-paragraph {
            margin-bottom: 10px;
            text-align: justify;
            animation: textFadeIn 0.25s ease-out;
        }

        /* Layout Component Stacks */
        .qa-stack,
        .quiz-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .qa-card,
        .quiz-card {
            background: var(--panel-2);
            border: 1px solid var(--line);
            border-radius: var(--radius-sm);
            padding: 12px;
            transition: transform 0.2s, border-color 0.2s;
        }

        .qa-question,
        .quiz-question {
            font-size: 13.5px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            gap: 6px;
            line-height: 1.4;
            margin-bottom: 8px;
        }

        .qa-question span,
        .quiz-question span {
            color: var(--primary);
            font-weight: 800;
        }

        .qa-answer {
            font-size: 12.5px;
            line-height: 1.5;
            color: var(--muted);
            padding-left: 14px;
            border-left: 2px solid var(--line);
        }

        /* --- New Interactive Sections Options Engine --- */
        .options-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
            margin-top: 8px;
        }

        .option-item {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            padding: 10px 12px;
            border-radius: var(--radius-sm);
            font-size: 12.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .option-item:hover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .option-item input[type="radio"] {
            accent-color: var(--primary);
        }

        /* Input Configuration for Fills */
        .fill-input {
            background: var(--panel-solid);
            border: 1px solid var(--line);
            padding: 6px 10px;
            border-radius: 8px;
            font-size: 12.5px;
            color: var(--text);
            width: 100%;
            max-width: 240px;
            outline: none;
            margin-top: 6px;
            transition: border-color 0.2s;
        }

        .fill-input:focus {
            border-color: var(--primary);
        }

        /* Writer Biography Structure */
        .writer-profile-box {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .writer-avatar-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--primary);
            display: grid;
            place-items: center;
            font-size: 18px;
            border: 1px solid var(--line);
            flex-shrink: 0;
        }

        .writer-bio-text h4 {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .writer-bio-text p {
            font-size: 12.5px;
            color: var(--muted);
            line-height: 1.5;
        }

        /* --- Desktop Viewport Up-Scaling Optimization --- */
        @media (min-width: 768px) {
            :root {
                --nav-h: 64px;
                --radius: 20px;
                --radius-sm: 14px;
            }

            .container {
                padding: 20px;
                gap: 20px;
                /* Side-by-side components grid framework for Desktop view symmetry */
                display: grid;
                grid-template-columns: repeat(2, 1fr);
            }

            .chapter-hero,
            .writer-panel {
                grid-column: span 2;
            }

            .nav-left h1 {
                font-size: 18px;
            }

            .chapter-hero h2 {
                font-size: 26px;
            }

            .chapter-hero p {
                font-size: 14px;
            }

            .options-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .fill-input {
                width: auto;
            }
        }

        @keyframes textFadeIn {
            from {
                opacity: 0;
                transform: translateY(2px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        * {
            user-select: none;
            -webkit-user-select: none;
            -webkit-touch-callout: none;
        }

        img {
            pointer-events: none;
            -webkit-user-drag: none;
        }
    </style>
</head>

<body>

    <nav>
        <div class="nav-left">
            <a href="../../home.html" class="back-link">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h1>English Library</h1>
        </div>
    </nav>

    <div class="container">

        <div class="chapter-hero">
            <span class="meta-badge">Class 9 • Chapter 3 • Poetry</span>
            <h2>The Little Girl</h2>
            <p>The Little Girl is a poignant story that explores the relationship between a father and his daughter,
                highlighting themes of love, understanding, and the innocence of childhood. 🎵</p>
        </div>

        <div class="panel" style="grid-column: span 2;">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="fa-solid fa-file-invoice"></i>
                    <h3>Central Idea of the Poem</h3>
                </div>
                <div class="lang-switch-box">
                    <button class="lang-btn active" onclick="switchSummaryLanguage('en', this)">English</button>
                    <button class="lang-btn" onclick="switchSummaryLanguage('hi', this)">हिंदी</button>
                </div>
            </div>
            <div class="summary-content-area" id="summaryViewPort">
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="fa-solid fa-list-check"></i>
                    <h3>Multiple Choice Questions</h3>
                </div>
            </div>
            <div class="quiz-stack">
                <div class="quiz-card">
                    <div class="quiz-question"><span>1.</span> Who is the little girl in the story?</div>
                    <div class="options-grid">
                        <label class="option-item"><input type="radio" name="mcq1"> Alice</label>
                        <label class="option-item"><input type="radio" name="mcq1"> Kezia</label>
                        <label class="option-item"><input type="radio" name="mcq1"> Margie</label>
                        <label class="option-item"><input type="radio" name="mcq1"> Anne</label>
                    </div>
                </div>

                

            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="fa-solid fa-circle-check"></i>
                    <h3>True / False Section</h3>
                </div>
            </div>
            <div class="quiz-stack">
                <div class="quiz-card">
                    <div class="quiz-question"><span>1.</span> Kezia was afraid of her father because he was very strict
                        and serious.</div>
                    <div class="options-grid" style="grid-template-columns: repeat(2, 1fr);">
                        <label class="option-item"><input type="radio" name="tf1"> True</label>
                        <label class="option-item"><input type="radio" name="tf1"> False</label>
                    </div>
                </div>

               

            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="fa-solid fa-pen-clip"></i>
                    <h3>Fill in the Blanks</h3>
                </div>
            </div>
            <div class="quiz-stack">
                <div class="quiz-card">
                    <div class="quiz-question"><span>1.</span> The name of the little girl in the story is ________.
                    </div>
                    <input type="text" class="fill-input" placeholder="Type your answer...">
                </div>

                

            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="fa-solid fa-graduation-cap"></i>
                    <h3>Conceptual Q&A Matrix</h3>
                </div>
            </div>
            <div class="qa-stack">
                <div class="qa-card">
                    <div class="qa-question"><span>Q1.</span> Who was Kezia?</div>
                    <div class="qa-answer">Kezia was a little girl who was afraid of her strict and serious father. She
                        misunderstood his behavior and thought he did not love her, but later she realized that he cared
                        deeply for her.</div>
                </div>

                

            </div>
        </div>

        <div class="panel writer-panel">
            <div class="panel-header" style="margin-bottom: 10px; padding-bottom: 6px;">
                <div class="panel-title">
                    <i class="fa-solid fa-user-pen"></i>
                    <h3>About the Writer</h3>
                </div>
            </div>
            <div class="writer-profile-box">
                <div class="writer-avatar-circle">
                    <i class="fa-solid fa-feather-pointed"></i>
                </div>
                <div class="writer-bio-text">
                    <h4>Katherine Mansfield</h4>
                    <p>Katherine Mansfield (1888–1923) was a renowned New Zealand-born modernist writer and one of the
                        most influential short story authors of the twentieth century. Her full name was Kathleen
                        Mansfield Beauchamp. She is celebrated for her sensitive portrayal of human emotions, family
                        relationships, childhood experiences, and everyday life. Mansfield's writing is known for its
                        psychological depth, realistic characters, and vivid descriptions. Some of her most famous works
                        include <i>The Garden Party</i>, <i>Bliss</i>, <i>Prelude</i>, and <i>The Doll's House</i>. The
                        chapter <i>"The Little Girl"</i> beautifully reflects her ability to explore the feelings and
                        perspectives of children while highlighting the importance of understanding and compassion
                        within families.</p>
                </div>
            </div>
        </div>

    </div>

    <script>
        const summaryDataAsset = {
    en: `
        <div class="summary-paragraph"><strong>Central Idea:</strong> "No Men Are Foreign" by James Kirkup conveys the powerful message of universal brotherhood and human unity. The poet emphasizes that all people, regardless of their nationality, race, religion, or language, are fundamentally the same. We share the same earth, breathe the same air, and experience similar joys, sorrows, needs, and emotions. Through the poem, Kirkup warns against hatred, discrimination, and war, explaining that harming others ultimately means harming ourselves. He encourages people to recognize their common humanity and live with peace, understanding, and mutual respect. The poem inspires readers to rise above narrow boundaries and work towards a world united by love, harmony, and compassion.</div>
    `,

    hi: `
        <div class="summary-paragraph"><strong>केंद्रीय विचार:</strong> "No Men Are Foreign" जेम्स किर्कप की एक प्रेरणादायक कविता है, जो विश्व-बंधुत्व और मानव एकता का संदेश देती है। कवि बताता है कि सभी मनुष्य, चाहे वे किसी भी देश, जाति, धर्म या भाषा के हों, मूल रूप से एक समान हैं। हम सभी एक ही पृथ्वी पर रहते हैं, एक ही हवा में सांस लेते हैं और समान भावनाओं, आवश्यकताओं तथा अनुभवों को साझा करते हैं। कविता घृणा, भेदभाव और युद्ध का विरोध करती है तथा यह समझाती है कि दूसरों को नुकसान पहुँचाना वास्तव में स्वयं मानवता को नुकसान पहुँचाना है। कवि लोगों से आग्रह करता है कि वे अपने साझा मानवत्व को पहचानें और प्रेम, शांति, सहिष्णुता तथा आपसी सम्मान के साथ जीवन व्यतीत करें। यह कविता हमें संकीर्ण सोच से ऊपर उठकर एकता, सद्भाव और करुणा से भरे विश्व के निर्माण की प्रेरणा देती है।</div>
    `
};
        function switchSummaryLanguage(langKey, elementRef) {
            document.querySelectorAll(".lang-btn").forEach(btn => btn.classList.remove("active"));
            if (elementRef) elementRef.classList.add("active");

            const viewport = document.getElementById("summaryViewPort");
            viewport.innerHTML = summaryDataAsset[langKey] || summaryDataAsset['en'];
        }

        document.addEventListener("DOMContentLoaded", () => {
            switchSummaryLanguage('en', null);
        });
        function applyThemeFromBrainHub() {

            const data = JSON.parse(
                localStorage.getItem("brainhub.app.v2") || "{}"
            );

            const theme = data.theme || "light";

            document.documentElement.dataset.theme =
                theme;

            const metaTheme = document.querySelector(
                'meta[name="theme-color"]'
            );

            if (metaTheme) {
                metaTheme.setAttribute(
                    "content",
                    theme === "dark"
                        ? "#121722"
                        : "#2563eb"
                );
            }
        }

        document.addEventListener(
            "DOMContentLoaded",
            applyThemeFromBrainHub
        );

        window.addEventListener("storage", (e) => {
            if (e.key === "brainhub.app.v2") {
                applyThemeFromBrainHub();
            }
        });

        /* Same tab sync */
        setInterval(applyThemeFromBrainHub, 500);
        // Jab bhi theme switch logic trigger ho, tab ye niche ka logic chala dena:
        function updateMetaThemeColor(isDark) {
            const metaTheme = document.querySelectorAll('meta[name="theme-color"]');
            metaTheme.forEach(meta => {
                if (meta.matches('(prefers-color-scheme: dark)') || isDark) {
                    // Agar dark mode hai
                    if (isDark) meta.setAttribute('content', '#121722');
                } else {
                    // Agar light mode hai toh pure white dikhega
                    meta.setAttribute('content', '#ffffff');
                }
            });
        }
    </script>
</body>

</html>